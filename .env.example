# board API（設定 → API設定 で発行。APIキーとAPIトークンは別々の値）
BOARD_API_KEY=your_board_api_key
BOARD_API_TOKEN=your_board_api_token

# Repsona API（URL の https://<ここ>.repsona.com の部分だけ入れる）
REPSONA_SPACE_ID=your_space_id
REPSONA_API_TOKEN=your_repsona_api_token

# Discord（チャンネル設定 → 連携サービス → ウェブフック で発行）
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXX/YYY

# ダッシュボードのBasic認証（URLを知っている人だけ入れるための合言葉）
DASHBOARD_USER=admin
DASHBOARD_PASS=changeme

# 滞留案件と判定する閾値（日数）
STALE_DAYS=14
